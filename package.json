{
  "name": "inwell-tumblr-advertisement",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "python backend/app.py",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tumblr:install-browsers": "playwright install chromium",
    "tumblr:inspect": "node scripts/tumblr-inspect.mjs",
    "tumblr:login": "node scripts/tumblr-login.mjs",
    "tumblr:runner:install-autostart": "powershell -ExecutionPolicy Bypass -File scripts/install-local-runner-autostart.ps1",
    "tumblr:runner:local": "node scripts/tumblr-local-runner.mjs",
    "tumblr:runner": "node scripts/tumblr-runner.mjs",
    "test": "npm run test:runner && npm run test:frontend && npm run test:backend",
    "test:runner": "node --test \"tests/runner/**/*.test.mjs\"",
    "test:frontend": "node --test \"tests/frontend/**/*.test.mjs\"",
    "test:backend": "python -m unittest discover -s backend/tests -p \"test_*.py\""
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "playwright": "^1.61.0",
    "typescript": "^5.6.3"
  }
}
